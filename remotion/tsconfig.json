{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["dom", "ES2022"],
    "jsx": "react",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["src/**/*", "remotion.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/CustomVideo.tsx",
    "src/PhosphorDemo.tsx",
    "src/QwenPawCPU.tsx",
    "src/SampleMVP.tsx",
    "src/TemplateMVP.tsx",
    "src/ThemeTest.tsx"
  ]
}
